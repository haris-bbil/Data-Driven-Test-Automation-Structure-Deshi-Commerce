{
  "name": "ecommerce-automation",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "TMPDIR=$PWD/.tmp npx playwright test",
    "test:merchantPanel": "npx playwright test ./src/tests/merchantPanelCoreModuleTest --workers=6 --fully-parallel",
    "test:orderCreate": "TMPDIR=$PWD/.tmp npx playwright test ./src/tests/merchantPanelCoreModuleTest/orderPageTest/orderCreate.spec.ts --workers=3 --fully-parallel",
    "test:chromium": "TMPDIR=$PWD/.tmp npx playwright test --project=chromium --workers=9",
    "test:firefox": "TMPDIR=$PWD/.tmp npx playwright test --project=firefox --workers=9",
    "test:webkit": "TMPDIR=$PWD/.tmp npx playwright test --project=webkit --workers=9",
    "test:all-parallel": "npm-run-all --parallel test:chromium test:firefox test:webkit",
    "test:chromium:headed": "TMPDIR=$PWD/.tmp npx playwright test --project=chromium --workers=9 --headed",
    "test:firefox:headed": "TMPDIR=$PWD/.tmp npx playwright test --project=firefox --workers=9 --headed",
    "test:webkit:headed": "TMPDIR=$PWD/.tmp npx playwright test --project=webkit --workers=9 --headed",
    "test:all-parallel:headed": "npm-run-all --parallel test:chromium:headed test:firefox:headed test:webkit:headed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.58.0",
    "@types/dotenv": "^8.2.3",
    "@types/node": "^25.0.8",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  }
}
